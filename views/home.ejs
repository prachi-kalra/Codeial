
    <h1>Codeial/<%=title%></h1>
   <section id="feed-posts">
    <h4>POSTS</h4>
    <form action="/posts/create" id="new-post-form" method="POST">
        <textarea name="content" cols="30" row="3" placeholder="Type Here...." required></textarea>
        <input type="submit" value="Post">

    </form>
    <div id="posts-list-container">
        <ul>
            <%for(post of posts){%>
                <li>
                    <%=post.content%>
                    <br>
                    <small>
                        <%=post.user.name%>
                    </small>
                </li>
                <%}%>
        </ul>
    </div>
   </section>

