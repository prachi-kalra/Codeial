<link rel="stylesheet" href="/css/home.css">
<div id="home-container">
   <div id="feed-posts">
    <h3>POSTS</h3>
    <% if(locals.user){%>
    <form action="/posts/create" id="new-post-form" method="POST">
        <textarea name="content" cols="30" row="3" placeholder="Type Here...." required></textarea>
        <input type="submit" value="Post">

    </form>
    <%}%>
    <div id="posts-list-container">
        <ul>
            <%for(post of posts){%>
                 <%-include('_post')-%>
                <%}%>
        </ul>
    </div>
</div>
   <div id="user-friends">
    <h3>FRIENDS !</h3>
    <% for(u of all_users){%>
        <p>
            <a href="/users/profile/<%=u.id %>">
                <%= u.name %>
            </a>
        </p>
       
        <%}%>

    </div>
</div>
